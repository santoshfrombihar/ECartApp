@model User;

<div class="container py-4" style="max-width: 860px;">

    <div class="row g-3">

        <!-- LEFT SIDEBAR -->
        <div class="col-md-4">
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body text-center py-4">
                    <div class="avatar-circle mb-2">
                        @if (!string.IsNullOrEmpty(Model.UserProfile?.Photo))
                        {
                            <img src="@Model.UserProfile.Photo" id="profilePreview" class="rounded-circle img-thumbnail" style="width: 80px; height: 80px; object-fit: cover;" />
                        }
                        else
                        {
                            <span id="initials">@Model.FirstName?[0]</span>
                        }
                    </div>

                    <form id="photoForm" asp-action="UploadPhoto" asp-controller="UserProfile" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="userId" value="@Model.Id" />
        
                        <label for="photoInput" class="btn btn-sm btn-outline-secondary mt-1 mb-2" style="cursor:pointer;">
                            Change Photo
                        </label>
                        <input type="file" name="photo" id="photoInput" accept="image/*" style="display:none;" />
                    </form>
    
                    <p class="text-muted" style="font-size:11px;">Upload starts automatically</p>
                </div>
                <div class="border-top px-3 py-3">
                    <div class="row g-2">
                        <div class="col-4">
                            <div class="stat-box bg-primary bg-opacity-10">
                                <div class="stat-num text-primary">24</div>
                                <div class="stat-label">Orders</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="stat-box bg-success bg-opacity-10">
                                <div class="stat-num text-success">3</div>
                                <div class="stat-label">Wishlist</div>
                            </div>
                        </div>
                        <div class="col-4">
                            <div class="stat-box bg-warning bg-opacity-10">
                                <div class="stat-num text-warning">8</div>
                                <div class="stat-label">Reviews</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Nav -->
                <div class="border-top px-3 pt-3 pb-2">
                    <ul class="nav nav-pills flex-column gap-1">
                        <li class="nav-item"><a class="nav-link active" href="#">My Profile</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">My Orders</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Wishlist</a></li>
                        <li class="nav-item"><a class="nav-link" href="#">Payment Methods</a></li>
                        <li class="nav-item"><a class="nav-link text-danger" href="#">Logout</a></li>
                    </ul>
                </div>
            </div>
        </div>

        <!-- RIGHT MAIN -->
        <div class="col-md-8">

            <!-- Personal Info -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="section-title mb-0">Personal Information</div>
                        <button class="btn btn-sm btn-outline-primary"
                                data-bs-toggle="modal"
                                data-bs-target="#editProfileModal">
                            Edit
                        </button>
                    </div>
                    <div class="row g-3">
                        <div class="col-6">
                            <div class="info-label">Full Name</div>
                            <div class="info-value">@Model.FirstName @Model.MiddleName @Model.LastName</div>
                        </div>
                        <div class="col-6">
                            <div class="info-label">Username</div>
                            <div class="info-value">@Model.FirstName</div>
                        </div>
                        <div class="col-6">
                            <div class="info-label">Email Address</div>
                            <div class="info-value">@Model.Email</div>
                        </div>
                        <div class="col-6">
                            <div class="info-label">Phone Number</div>
                            <div class="info-value">@Model.UserProfile?.PhoneNumber</div>
                        </div>
                        <div class="col-6">
                            <div class="info-label">Date of Birth</div>
                            <div class="info-value">@Model.UserProfile?.Dob</div>
                        </div>
                        <div class="col-6">
                            <div class="info-label">Gender</div>
                            <div class="info-value">@Model.UserProfile?.Gender</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal fade" id="editProfileModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">

                        <form asp-controller="UserProfile" asp-action="UpdateProfile" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Edit Profile</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body">

                                <input type="hidden" name="Id" value="@Model.Id" />

                                <div class="mb-2">
                                    <label>First Name</label>
                                    <input type="text" asp-for="FirstName" class="form-control" value="@Model.FirstName" />
                                </div>

                                <div class="mb-2">
                                    <label>Middle Name</label>
                                    <input type="text" asp-for="MiddleName" class="form-control" value="@Model.MiddleName" />
                                </div>

                                <div class="mb-2">
                                    <label>Last Name</label>
                                    <input type="text" asp-for="LastName" class="form-control" value="@Model.LastName" />
                                </div>

                                <div class="mb-2">
                                    <label>Email</label>
                                    <input type="email" asp-for="Email" class="form-control" value="@Model.Email" />
                                </div>

                                <div class="mb-2">
                                    <label>Phone</label>
                                    <input type="text" asp-for="UserProfile.PhoneNumber" class="form-control" value="@Model.UserProfile?.PhoneNumber" />
                                </div>

                                <div class="mb-2">
                                    <label>Birth Date</label>
                                    <input type="date"  asp-for="UserProfile.Dob" class="form-control" value="@Model.UserProfile?.Dob.ToString("yyyy-MM-dd")" />
                                </div>

                                <div class="mb-2">
                                    <label class="form-label">Gender</label>

                                    <div class="form-check">
                                        <input type="radio" asp-for="UserProfile.Gender" value="Male" class="form-check-input" />
                                        <label class="form-check-label">Male</label>
                                    </div>

                                    <div class="form-check">
                                        <input type="radio" asp-for="UserProfile.Gender" value="Female" class="form-check-input" />
                                        <label class="form-check-label">Female</label>
                                    </div>
                                </div>

                            </div>

                            <div class="modal-footer">
                                <button type="submit" class="btn btn-primary">Save</button>
                            </div>

                        </form>

                    </div>
                </div>
            </div>
            <!-- Saved Addresses -->
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="section-title mb-0">Saved Addresses</div>
                        <button class="btn btn-sm btn-outline-primary" style="font-size:12px;"
                                data-bs-toggle="modal"
                                data-bs-target="#addAddressModal">
                            + Add New
                        </button>
                    </div>
                    @foreach (var address in Model.UserAddresses)
                    {
                        <div class="d-flex flex-column gap-2">

                            <!-- Address 1 -->
                            <div class="address-card default">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <div class="d-flex gap-2">
                                        <a href="#"
                                               class="text-primary edit-address-btn"
                                               style="font-size:12px;"
                                               data-bs-toggle="modal"
                                               data-bs-target="#editAddressModal"
                                               data-id="@address.Id"
                                               data-type="@address.AddressType"
                                               data-address="@address.Address"
                                               data-city="@address.City"
                                               data-district="@address.District"
                                               data-state="@address.State"
                                               data-pincode="@address.PinCode"
                                               data-contact="@address.ContactNumber">
                                            Edit
                                        </a>
                                        <a asp-action="DeleteAddress" asp-route-addressId="@address.Id" style="font-size:12px;" class="text-danger">Delete</a>
                                    </div>
                                </div>
                                <p class="mb-0 fw-semibold" style="font-size:14px;">@address.AddressType</p>
                                <p class="mb-0 text-muted" style="font-size:13px;">@address.Address @address.City @address.District @address.State @address.PinCode</p>
                                <p class="mb-0 text-muted" style="font-size:12px;">@address.ContactNumber</p>
                                <p class="mb-0 text-muted" style="font-size:12px;">@address.AlternateNumber</p>
                            </div>
                        </div>
                    }
                </div>
            </div>

            <div class="modal fade" id="addAddressModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">

                        <form asp-controller="UserProfile" asp-action="AddAddress" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Add New Address</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>

                            <div class="modal-body">

                                <input type="hidden" name="UserId" value="@Model.Id" />

                                <div class="mb-2">
                                    <label class="form-label">Address Type</label>

                                     <div class="form-check">
                                        <input type="radio" name="AddressType" value="Home" class="form-check-input" />
                                        <label class="form-check-label">Home</label>
                                    </div>

                                    <div class="form-check">
                                        <input type="radio" name="AddressType" value="Work" class="form-check-input" />
                                        <label class="form-check-label">Work</label>
                                    </div>
                                </div>

                                <div class="mb-2">
                                    <label>Address</label>
                                    <input type="text" name="Address" class="form-control" />
                                </div>

                                <div class="mb-2">
                                    <label>City</label>
                                    <input type="text" name="City" class="form-control" />
                                </div>

                                <div class="mb-2">
                                    <label>State</label>
                                    <input type="text" name="District" class="form-control" />
                                </div>

                                <div class="mb-2">
                                    <label>State</label>
                                    <input type="email" name="State" class="form-control" />
                                </div>

                                <div class="mb-2">
                                    <label>Pin Code</label>
                                    <input type="text" name="PinCode" class="form-control" />
                                </div>

                                <div class="mb-2">
                                    <label>Contact Number</label>
                                    <input type="text" name="ContactNumber" class="form-control" />
                                </div>

                                <div class="mb-2">
                                    <label>Alternate Number</label>
                                    <input type="text" name="AlternateNumber" class="form-control" />
                                </div>
                             

                            </div>

                            <div class="modal-footer">
                                <button type="submit" class="btn btn-primary">Save</button>
                            </div>

                        </form>

                    </div>
                </div>
            </div>

            <div class="modal fade" id="editAddressModal" tabindex="-1">
                <div class="modal-dialog">
                    <div class="modal-content">
                        <form asp-controller="UserProfile" asp-action="EditAddress" method="post">
                            <div class="modal-header">
                                <h5 class="modal-title">Edit Address</h5>
                                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                            </div>
                            <div class="modal-body">
                                <input type="hidden" name="Id" id="edit-id" />
                    
                                <div class="mb-2">
                                    <label class="form-label">Address Type</label>
                                    <select name="AddressType" id="edit-type" class="form-control">
                                        <option value="Home">Home</option>
                                        <option value="Work">Work</option>
                                    </select>
                                </div>

                                <div class="mb-2">
                                    <label>Address</label>
                                    <input type="text" name="Address" id="edit-address" class="form-control" />
                                </div>

                                <div class="row">
                                    <div class="col-6 mb-2">
                                        <label>City</label>
                                        <input type="text" name="City" id="edit-city" class="form-control" />
                                    </div>
                                    <div class="col-6 mb-2">
                                        <label>District</label>
                                        <input type="text" name="District" id="edit-district" class="form-control" />
                                    </div>
                                </div>

                                <div class="row">
                                    <div class="col-6 mb-2">
                                        <label>State</label>
                                        <input type="text" name="State" id="edit-state" class="form-control" />
                                    </div>
                                    <div class="col-6 mb-2">
                                        <label>Pin Code</label>
                                        <input type="text" name="PinCode" id="edit-pincode" class="form-control" />
                                    </div>
                                </div>

                                <div class="mb-2">
                                    <label>Contact Number</label>
                                    <input type="text" name="ContactNumber" id="edit-contact" class="form-control" />
                                </div>
                            </div>
                            <div class="modal-footer">
                                <button type="submit" class="btn btn-primary">Update Address</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <!-- Account Security -->
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="section-title">Account & Security</div>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                            <div>
                                <div class="info-value">Password</div>
                                <div class="info-label">Last changed 3 months ago</div>
                            </div>
                            <button class="btn btn-sm btn-outline-secondary" style="font-size:12px;">Change</button>
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-2 border-bottom">
                            <div>
                                <div class="info-value">Two-Factor Authentication</div>
                                <div class="info-label">Add extra security to your account</div>
                            </div>
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" role="switch" checked style="cursor:pointer;">
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center py-2">
                            <div>
                                <div class="info-value">Email Notifications</div>
                                <div class="info-label">Orders, offers, and updates</div>
                            </div>
                            <div class="form-check form-switch mb-0">
                                <input class="form-check-input" type="checkbox" role="switch" checked style="cursor:pointer;">
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>