@using ECartApp.DTO_s
@model IEnumerable<ProductDto> 
<div class="d-flex">
    <!-- Sidebar -->
    <div class="sidebar">
       
        <div class="brand">SHOP<span>PULSE</span></div>
        <div class="mt-3">
            <div class="nav-section-label">Main</div>
            <a class="nav-link-custom active" href="#"><i class="bi bi-grid-1x2"></i> Dashboard</a>
            <a class="nav-link-custom" href="#"><i class="bi bi-bag"></i> Orders</a>
            <a class="nav-link-custom" href="#"><i class="bi bi-box-seam"></i> Products</a>
            <a class="nav-link-custom" href="#"><i class="bi bi-people"></i> Customers</a>
            <div class="nav-section-label mt-2">Analytics</div>
            <a class="nav-link-custom" href="#"><i class="bi bi-bar-chart-line"></i> Reports</a>
            <a class="nav-link-custom" href="#"><i class="bi bi-graph-up-arrow"></i> Revenue</a>
            <a class="nav-link-custom" href="#"><i class="bi bi-megaphone"></i> Marketing</a>
            <div class="nav-section-label mt-2">Store</div>
            <a class="nav-link-custom" href="#"><i class="bi bi-tags"></i> Discounts</a>
            <a class="nav-link-custom" href="#"><i class="bi bi-truck"></i> Shipping</a>
            <a class="nav-link-custom" href="#"><i class="bi bi-gear"></i> Settings</a>
        </div>
        <!-- Admin -->
    </div>

    <!-- Main -->
    <div class="main-content flex-grow-1">
        <!-- Topbar -->
        <div class="topbar">
            <div>
                <div style="font-weight:700;font-size:1.05rem;color:#1a1f36;">Dashboard Overview</div>
                <div style="font-size:0.78rem;color:#8a93b2;">Wednesday, April 08, 2026</div>
                <p></p>
            </div>
            <div class="d-flex align-items-center gap-3">
                <input class="search-box" type="text" placeholder="&#x1F50D;  Search orders, products...">
                <div class="position-relative" style="cursor:pointer;">
                    <i class="bi bi-cart" style="font-size:1.2rem;color:#4a5272;">@ViewBag.CartCount </i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.6rem;"></span>
                </div>
                <div class="position-relative" style="cursor:pointer;">
                    <i class="bi bi-bell" style="font-size:1.2rem;color:#4a5272;"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size:0.6rem;"></span>
                </div>
               
                <div class="avatar-container">
                    <div class="avatar">SA</div>
                    <div class="avatar-dropdown">
                        <a asp-controller="userprofile" asp-action="userprofile" asp-route-userId="@ViewBag.UserId">Profile</a>
                        <a asp-controller="Auth" asp-action="Login">Sign Out</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="row"> 
        @foreach (var item in Model)
        {
                <div class="product-card col-12 col-sm-6 col-md-4 mb-4">

                <div class="badge">Hot</div>
                <div class="product-tumb">
                        <img src="https://m.media-amazon.com/images/I/71f3BmjCwtL._SY695_.jpg" alt="Product Image">
                </div>
                <div class="product-details">
                    <span class="product-catagory">@item.Type</span>
                    <h4><a href="">@item.ProductName</a></h4>
                    <p>@item.ProductDescription</p>

                    <div class="product-options">
                        <strong>Color:</strong>
                        <span class="color-dot" style="background-color: #222;"></span>
                        <span class="color-dot" style="background-color: #f1c40f;"></span>
                    </div>

                    <div class="product-rating">
                        <span>★★★★☆</span> <small>(42 Reviews)</small>
                    </div>

                    <div class="product-bottom-details">
                        <div class="product-price"><small>$99.00</small>@item.Price</div>
                        <div class="product-links">
                                @if (item.IsProductInCart)
                                {
                                    <button class="btn-cart" disabled style="opacity: 0.6; cursor: not-allowed;">
                                        <i class="fa fa-check"></i> In Cart
                                    </button>
                                }
                                else
                                {
                                    <button class="btn-cart" onclick="location.href='/Order/AddToCart?productId=@item.Id'">
                                        <i class="fa fa-shopping-cart"></i> Add to Cart
                                    </button>
                                }
                                <button class="btn-buy" onclick="location.href='/Order/OrderDetails?productId=@item.Id'">Buy Now</button>
                        </div>
                    </div>
                </div>
            </div>
        }
        </div>
        <div style="height:2rem;"></div>
    </div>
</div>