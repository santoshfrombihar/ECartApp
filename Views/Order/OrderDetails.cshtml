@using ECartApp.DTO_s
@model OrderDetailsDto

<div class="page-wrap">
    <!-- Nav -->
    <div class="topnav">
        <div class="brand">SHOP<span>PULSE</span></div>
        <div style="color:#8a93b2;font-size:0.8rem;display:flex;align-items:center;gap:6px;">
            <i class="bi bi-shield-lock" style="font-size:0.9rem;color:#1a9e5f;"></i> Secure Checkout
        </div>
    </div>

    <!-- Steps -->
    <div class="step-bar">
        <div class="d-flex align-items-center justify-content-center gap-1">
            <div class="step done"><div class="step-num"><i class="bi bi-check" style="font-size:0.7rem;"></i></div><span class="step-lbl">Cart</span></div>
            <div class="step-line"></div>
            <div class="step active"><div class="step-num">2</div><span class="step-lbl">Checkout</span></div>
            <div class="step-line"></div>
            <div class="step inactive"><div class="step-num">3</div><span class="step-lbl">Payment</span></div>
            <div class="step-line"></div>
            <div class="step inactive"><div class="step-num">4</div><span class="step-lbl">Confirmation</span></div>
        </div>
    </div>

    <div class="container-lg py-4">
        <div class="row g-4">

            <!-- LEFT: Details -->
            <div class="col-12 col-lg-7">

                <!-- Cart Items Section -->
                @if (Model.OrderItems.Any())
                {
                    <div class="card-box">
                        <h6><i class="bi bi-bag" style="color:#6c8af7;margin-right:6px;font-size:0.9rem;"></i>Cart Items (@Model.OrderItems.Count)</h6>
                        
                        @foreach (var item in Model.OrderItems)
                        {
                            <div class="product-line">
                                <div class="prod-img">
                                    @if (!string.IsNullOrEmpty(item.ProductImage))
                                    {
                                        <img src="@item.ProductImage" alt="@item.ProductName" style="width:60px;height:60px;object-fit:cover;border-radius:4px;">
                                    }
                                    else
                                    {
                                        <div style="width:60px;height:60px;background:#f0f0f0;border-radius:4px;display:flex;align-items:center;justify-content:center;">
                                            <i class="bi bi-image" style="font-size:1.5rem;color:#ccc;"></i>
                                        </div>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <div class="prod-name">@item.ProductName</div>
                                    <div class="prod-meta">Qty: @item.Quantity &nbsp;|&nbsp; ₹@item.UnitPrice.ToString("F2")</div>
                                </div>
                                <div class="text-end">
                                    <div style="font-size:0.95rem;font-weight:700;color:#1a1f36;">₹@item.TotalPrice.ToString("F2")</div>
                                </div>
                            </div>
                        }
                    </div>
                }

                <!-- Buy Now Product Section (If exists) -->
                @if (Model.BuyNowProduct != null)
                {
                    <div class="card-box" style="border-left: 4px solid #ff6b35;">
                        <h6><i class="bi bi-lightning-charge" style="color:#ff6b35;margin-right:6px;font-size:0.9rem;"></i>Buy Now Product</h6>
                        
                        <div class="product-line" style="background:#fff9f5;padding:12px;border-radius:6px;">
                            <div class="prod-img">
                                @if (!string.IsNullOrEmpty(Model.BuyNowProduct.ProductImage))
                                {
                                    <img src="@Model.BuyNowProduct.ProductImage" alt="@Model.BuyNowProduct.ProductName" style="width:60px;height:60px;object-fit:cover;border-radius:4px;">
                                }
                                else
                                {
                                    <div style="width:60px;height:60px;background:#f0f0f0;border-radius:4px;display:flex;align-items:center;justify-content:center;">
                                        <i class="bi bi-image" style="font-size:1.5rem;color:#ccc;"></i>
                                    </div>
                                }
                            </div>
                            <div class="flex-grow-1">
                                <div class="prod-name">@Model.BuyNowProduct.ProductName</div>
                                <div class="prod-meta">Qty: @Model.BuyNowProduct.Quantity &nbsp;|&nbsp; ₹@Model.BuyNowProduct.UnitPrice.ToString("F2")</div>
                                <span class="badge bg-warning" style="font-size:0.7rem;margin-top:6px;">New Item</span>
                            </div>
                            <div class="text-end">
                                <div style="font-size:0.95rem;font-weight:700;color:#ff6b35;">₹@Model.BuyNowProduct.TotalPrice.ToString("F2")</div>
                            </div>
                        </div>
                    </div>
                }

                <!-- Delivery Address Section -->
                <div class="card-box">
                    <h6><i class="bi bi-geo-alt" style="color:#6c8af7;margin-right:6px;font-size:0.9rem;"></i>Delivery Address</h6>
                    @if (Model.UserAddresses.Any())
                    {
                        <div style="display:grid;gap:12px;">
                            @foreach (var address in Model.UserAddresses)
                            {
                                <label class="address-radio">
                                    <input type="radio" name="selectedAddress" value="@address.Id" @(address.Id == Model.UserAddresses.First().Id ? "checked" : "")>
                                    <div class="address-box">
                                        <div style="font-weight:600;color:#1a1f36;">@address.AddressType</div>
                                        <div style="font-size:0.9rem;color:#4a5272;margin-top:4px;">
                                            @address.Address, @address.City, @address.State - @address.PinCode
                                        </div>
                                        <div style="font-size:0.85rem;color:#8a93b2;margin-top:4px;">📞 @address.ContactNumber</div>
                                    </div>
                                </label>
                            }
                        </div>
                    }
                    else
                    {
                        <div style="padding:16px;background:#f5f7fa;border-radius:6px;color:#8a93b2;text-align:center;">
                            No addresses saved. Please add an address in your profile.
                        </div>
                    }
                </div>

                <!-- Payment Method Section -->
                <div class="card-box">
                    <h6><i class="bi bi-credit-card" style="color:#6c8af7;margin-right:6px;font-size:0.9rem;"></i>Payment Method</h6>
                    <div style="display:grid;gap:10px;">
                        <label class="payment-radio">
                            <input type="radio" name="paymentMethod" value="UPI" checked>
                            <span><i class="bi bi-phone"></i> UPI</span>
                        </label>
                        <label class="payment-radio">
                            <input type="radio" name="paymentMethod" value="Card">
                            <span><i class="bi bi-credit-card"></i> Debit/Credit Card</span>
                        </label>
                        <label class="payment-radio">
                            <input type="radio" name="paymentMethod" value="COD">
                            <span><i class="bi bi-cash-coin"></i> Cash on Delivery</span>
                        </label>
                    </div>
                </div>

            </div>

            <!-- RIGHT: Price Summary -->
            <div class="col-12 col-lg-5">
                <div class="card-box sticky-top" style="top:20px;">
                    <h6 style="margin-bottom:16px;"><i class="bi bi-calculator" style="color:#6c8af7;margin-right:6px;"></i>Price Summary</h6>
                    
                    <div class="price-row">
                        <span>Subtotal</span>
                        <span>₹@Model.TotalAmount.ToString("F2")</span>
                    </div>
                    <div class="price-row">
                        <span>Discount (20%)</span>
                        <span style="color:#1a9e5f;">-₹@Model.DiscountAmount.ToString("F2")</span>
                    </div>
                    <div class="price-row">
                        <span>GST (18%)</span>
                        <span>₹@Model.GSTAmount.ToString("F2")</span>
                    </div>
                    <div class="price-row" style="border-top:2px solid #f0f2f5;padding-top:12px;margin-top:12px;font-weight:700;font-size:1.1rem;color:#1a1f36;">
                        <span>Total Amount</span>
                        <span>₹@Model.FinalAmount.ToString("F2")</span>
                    </div>

                    <!-- Coupon Section -->
                    <div style="margin-top:16px;">
                        <input type="text" placeholder="Enter coupon code" class="form-control form-control-sm" id="couponCode" style="margin-bottom:8px;">
                        <button class="btn btn-sm btn-outline-primary w-100" onclick="applyCoupon()">Apply Coupon</button>
                    </div>

                    <!-- Place Order Form -->
                    <form method="post" action="@Url.Action("PlaceOrder", "Order")" style="margin-top:20px;">
                        <input type="hidden" name="paymentMethod" id="paymentMethodInput" value="UPI">
                        <input type="hidden" name="couponCode" id="couponCodeInput" value="">
                        
                        <button type="submit" class="btn btn-primary w-100" style="height:48px;font-weight:600;">
                            <i class="bi bi-check-circle"></i> Place Order
                        </button>
                    </form>

                    <button type="button" class="btn btn-outline-secondary w-100 mt-2" onclick="history.back()">
                        <i class="bi bi-arrow-left"></i> Continue Shopping
                    </button>
                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .address-radio input[type="radio"] { margin-right: 12px; }
    .address-box { padding: 12px; border: 1px solid #e0e6ed; border-radius: 6px; }
    .address-radio input[type="radio"]:checked + .address-box { border-color: #6c8af7; background: #f8f9ff; }
    
    .payment-radio input[type="radio"] { margin-right: 12px; }
    .payment-radio span { display: inline-flex; align-items: center; gap: 8px; }
    .payment-radio input[type="radio"]:checked + span { color: #6c8af7; font-weight: 600; }
    
    .price-row { display: flex; justify-content: space-between; margin-bottom: 12px; color: #4a5272; }
    .card-box { background: #fff; padding: 20px; border-radius: 8px; margin-bottom: 20px; box-shadow: 0 2px 8px rgba(0,0,0,0.08); }
    .product-line { display: grid; grid-template-columns: 60px 1fr auto; gap: 16px; padding: 12px 0; border-bottom: 1px solid #f0f2f5; align-items: center; }
    .product-line:last-child { border-bottom: none; }
    .prod-name { font-weight: 600; color: #1a1f36; }
    .prod-meta { font-size: 0.85rem; color: #8a93b2; }
</style>

<script>
    // Update payment method on form submission
    document.querySelectorAll('input[name="paymentMethod"]').forEach(radio => {
        radio.addEventListener('change', function() {
            document.getElementById('paymentMethodInput').value = this.value;
        });
    });

    function applyCoupon() {
        const couponCode = document.getElementById('couponCode').value;
        document.getElementById('couponCodeInput').value = couponCode;
        alert('Coupon "' + couponCode + '" applied!');
    }
</script>